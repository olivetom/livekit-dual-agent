# ── LiveKit Cloud / self-hosted ──────────────────────────────────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxx
LIVEKIT_API_SECRET=your_api_secret

# ── OpenAI  (foreground fast voice agent) ───────────────────────────────────
OPENAI_API_KEY=sk-...
FOREGROUND_LLM_MODEL=gpt-4o-mini   # or gpt-4o-realtime-preview

# ── Anthropic  (background reasoning agent) ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
BACKGROUND_LLM_MODEL=claude-sonnet-4-6

# ── Speech providers ────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_key
ELEVENLABS_API_KEY=your_elevenlabs_key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # Rachel

# ── Tuning ───────────────────────────────────────────────────────────────────
BACKGROUND_TIMEOUT=8.0   # max seconds to wait for background agent result

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
